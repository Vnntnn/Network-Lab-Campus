# Docker compose runtime settings
WEB_PORT=80

# Set your real public origin for browser access.
# Example: CORS_ORIGINS=https://app.example.com
CORS_ORIGINS=http://localhost

# Keep default SQLite volume path unless you are switching to PostgreSQL.
DATABASE_URL=sqlite+aiosqlite:///./data/nexus_edu.db

# Optional frontend build-time overrides.
VITE_API_BASE_URL=/api/v1
VITE_WS_BASE_URL=
