[Unit]
Description=Network Configuration Management Platform API
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/network-platform/backend
EnvironmentFile=/etc/network-platform/backend.env
ExecStart=/opt/network-platform/backend/.venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
